{
  "info": {
    "_postman_id": "10de6bc9-4743-4d5e-a306-61b7b8008a54",
    "name": "ClickUp Tasks API Course Project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "55097629",
    "_collection_link": "https://go.postman.co/collection/55097629-10de6bc9-4743-4d5e-a306-61b7b8008a54?source=collection_link"
  },
  "item": [
    {
      "name": "Positive Scenarios",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "let taskName = \"Course Task \" + Date.now();\r",
                  "\r",
                  "pm.environment.set(\"task_name\", taskName);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is less than 2000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "let response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Task was created\", function () {\r",
                  "    pm.expect(response.id).to.exist;\r",
                  "    pm.expect(response.name).to.eql(pm.environment.get(\"task_name\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Task has required fields\", function () {\r",
                  "    pm.expect(response).to.have.property(\"id\");\r",
                  "    pm.expect(response).to.have.property(\"name\");\r",
                  "    pm.expect(response).to.have.property(\"status\");\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"task_id\", response.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"name\": \"{{task_name}}\",\r\n  \"description\": \"Task created from Postman course project\",\r\n  \"status\": \"to do\",\r\n  \"priority\": 3\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/list/{{list_id}}/task",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "list",
                "{{list_id}}",
                "task"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Task",
